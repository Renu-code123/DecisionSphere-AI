# DecisionSphere AI - Environment Configuration
# Copy this file to .env and fill in your values

# === REQUIRED ===
# Get your free API key from: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=

# === OPTIONAL (defaults are fine for local dev) ===
# Use SQLite by default (no setup needed)
DATABASE_URL=sqlite:///./decisionsphere.db

# Change this in production!
SECRET_KEY=super-secret-decisionsphere-ai-token-key-2026

ENVIRONMENT=development
